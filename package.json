{
  "name": "convex-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "convex dev --start 'vite --open'",
    "build": "tsc -b && vite build",
    "lint": "tsc && ultracite check",
    "postinstall": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "preview": "vite preview",
    "deploy": "convex deploy --cmd 'pnpm run build' --cmd-url-env-var-name VITE_CONVEX_URL && static-hosting upload",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@astryxdesign/core": "^0.1.4",
    "@astryxdesign/theme-neutral": "^0.1.4",
    "@convex-dev/better-auth": "^0.12.5",
    "@convex-dev/r2": "^0.10.2",
    "@convex-dev/static-hosting": "^0.1.4",
    "@heroicons/react": "^2.2.0",
    "@hono/zod-validator": "^0.8.0",
    "@stylexjs/stylex": "^0.18.3",
    "@tanstack/react-form": "^1.33.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/router-plugin": "^1.168.19",
    "better-auth": "~1.6.15",
    "convex": "^1.42.1",
    "convex-helpers": "^0.1.120",
    "hono": "^4.12.30",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astryxdesign/cli": "^0.1.4",
    "@edge-runtime/vm": "^5.0.0",
    "@inlang/paraglide-js": "^2.21.0",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "convex-test": "^0.0.54",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "playwright": "^1.61.1",
    "typescript": "^7.0.2",
    "ultracite": "^7.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vitest-browser-react": "^2.2.0"
  },
  "packageManager": "pnpm@11.12.0+sha512.820a6fbd0d9f04c226638002aead1e45340a9139dd5dc077c1d83ef44aa2481c8eb6637b4c9aa696a3c7e35ba818e49cf27213e5f2b91138d09b7a3e26e898ba"
}
